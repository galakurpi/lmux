#!/usr/bin/env python3
import json
import os
import socket
import sys


def port_file() -> str:
    return os.path.expanduser("~/.lmux/ptr.port")


def send_line(line: str, quiet: bool = False) -> int:
    try:
        with open(port_file(), "r", encoding="utf-8") as f:
            port = int(f.read().strip())
    except Exception as exc:
        print(f"lmuxctl: Lmux socket is not available: {exc}", file=sys.stderr)
        return 1

    try:
        with socket.create_connection(("127.0.0.1", port), timeout=3) as sock:
            sock.sendall(line.encode("utf-8") + b"\n")
            sock.shutdown(socket.SHUT_WR)
            response = sock.makefile("r", encoding="utf-8").readline().strip()
    except Exception as exc:
        print(f"lmuxctl: failed to contact Lmux: {exc}", file=sys.stderr)
        return 1

    if response and not quiet:
        print(response)
    return 0


def command_json(cmd: str, args: dict) -> str:
    return json.dumps({"cmd": cmd, "args": args}, separators=(",", ":"))


def current_target() -> tuple[str | None, str | None]:
    return os.environ.get("LMUX_WORKSPACE_ID"), os.environ.get("LMUX_SURFACE_ID")


def notify(argv: list[str], quiet: bool = False) -> int:
    title = "Notification"
    subtitle = ""
    body = ""
    workspace, surface = current_target()
    i = 0
    while i < len(argv):
        arg = argv[i]
        if arg == "--title" and i + 1 < len(argv):
            title = argv[i + 1]
            i += 2
        elif arg == "--subtitle" and i + 1 < len(argv):
            subtitle = argv[i + 1]
            i += 2
        elif arg == "--body" and i + 1 < len(argv):
            body = argv[i + 1]
            i += 2
        elif arg == "--workspace" and i + 1 < len(argv):
            workspace = argv[i + 1]
            i += 2
        elif arg == "--surface" and i + 1 < len(argv):
            surface = argv[i + 1]
            i += 2
        else:
            body = " ".join(argv[i:])
            break

    payload = "|".join([title, subtitle, body])
    if workspace and surface:
        return send_line(f"notify_target_async {workspace} {surface} {payload}", quiet=quiet)
    return send_line(command_json("notify", {"payload": payload}), quiet=quiet)


def status(argv: list[str], quiet: bool = False) -> int:
    if not argv:
        print("usage: lmuxctl status <working|waiting|done|idle> [message]", file=sys.stderr)
        return 2
    state = argv[0]
    message = " ".join(argv[1:])
    workspace, surface = current_target()
    return send_line(command_json("agent.status", {
        "workspace_id": workspace,
        "surface_id": surface,
        "status": state,
        "message": message,
    }), quiet=quiet)


def hook_message(payload: dict) -> str:
    for key in (
        "last_assistant_message",
        "message",
        "prompt",
        "system_message",
        "stopReason",
        "reason",
    ):
        value = payload.get(key)
        if isinstance(value, str) and value.strip():
            return value.strip()
    return ""


def lifecycle_hook(agent_label: str, argv: list[str]) -> int:
    event = argv[0] if argv else os.environ.get("hook_event_name", "")
    try:
        payload = json.load(sys.stdin)
    except Exception:
        payload = {}

    cwd = payload.get("cwd") or os.getcwd()
    project = os.path.basename(cwd.rstrip("/")) or cwd
    message = hook_message(payload)
    lowered = event.lower()

    working_events = {
        "session-start",
        "sessionstart",
        "startup",
        "resume",
        "userpromptsubmit",
        "prompt-submit",
        "pre-tool-use",
        "pretooluse",
        "post-tool-use",
        "posttooluse",
        "beforeagent",
        "before-agent",
        "beforetool",
        "before-tool",
        "beforemodel",
        "before-model",
        "subagentstart",
        "subagent-start",
    }
    waiting_events = {"notification", "permissionrequest", "permission-request"}
    done_events = {
        "stop",
        "session-end",
        "sessionend",
        "afteragent",
        "after-agent",
    }
    quiet = True

    if lowered in working_events:
        return status(["working", f"{agent_label} in {project}"], quiet=quiet)
    if lowered in waiting_events:
        status(["waiting", message or f"{agent_label} needs input"], quiet=quiet)
        return notify([
            "--title", agent_label,
            "--subtitle", "Needs input",
            "--body", message or "Waiting for approval or input",
        ], quiet=quiet)
    if lowered in {"subagentstop", "subagent-stop"}:
        return status(["done", message or f"{agent_label} subagent finished in {project}"], quiet=quiet)
    if lowered in done_events:
        status(["done", message or f"Completed in {project}"], quiet=quiet)
        return notify([
            "--title", agent_label,
            "--subtitle", f"Completed in {project}",
            "--body", message,
        ], quiet=quiet)
    return 0


def claude_hook(argv: list[str]) -> int:
    return lifecycle_hook("Claude Code", argv)


def main() -> int:
    if len(sys.argv) < 2 or sys.argv[1] in {"-h", "--help"}:
        print("usage: lmuxctl notify|status|claude-hook ...", file=sys.stderr)
        return 2
    command = sys.argv[1]
    argv = sys.argv[2:]
    if command == "notify":
        return notify(argv)
    if command == "status":
        return status(argv)
    if command == "claude-hook":
        return claude_hook(argv)
    if command == "hooks" and len(argv) >= 2 and argv[0] == "claude":
        return claude_hook(argv[1:])
    if command == "hooks" and len(argv) >= 2 and argv[0] == "codex":
        return lifecycle_hook("Codex", argv[1:])
    if command == "hooks" and len(argv) >= 2 and argv[0] == "gemini":
        return lifecycle_hook("Gemini", argv[1:])
    if command == "hooks" and len(argv) >= 2 and argv[0] == "aider":
        return lifecycle_hook("Aider", argv[1:])
    if command == "hooks":
        return 0
    return send_line(" ".join(sys.argv[1:]))


if __name__ == "__main__":
    raise SystemExit(main())
